DB_NAME=syncroom
DB_USERNAME=syncroom
DB_PASSWORD=syncroom

JWT_SECRET=your-256-bit-secret-key-change-in-production-minimum-32-characters
JWT_ACCESS_EXPIRATION=900000 # 15 minutes in milliseconds
JWT_REFRESH_EXPIRATION=2592000000
APP_PORT=8080
POSTGRES_PORT=5432

# Публичный URL API (за nginx), без завершающего /
APP_PUBLIC_BASE_URL=http://localhost:8080
# Для S3+CDN: URL CDN для объектов в бакете (если пусто — как APP_PUBLIC_BASE_URL)
APP_CDN_PUBLIC_URL=https://cdn.syncroom.ru

SYNCROOM_STORAGE_TYPE=local
SYNCROOM_STORAGE_LOCAL_DIR=./data/storage

# Яндекс Object Storage (если SYNCROOM_STORAGE_TYPE=s3)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=syncroom-static
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_KEY_PREFIX=syncroom

# Полный URL дефолтной аватарки seat-ботов на CDN
APP_SEAT_BOT_DEFAULT_AVATAR_URL=/icons/icon-192.png
# Точечные аватарки для каждого типа (опционально, иначе берется default)
APP_SEAT_BOT_WORK_FOCUS_BUDDY_AVATAR_URL=https://cdn.syncroom.ru/syncroom/bots/work-focus-buddy.png
APP_SEAT_BOT_STUDY_HELPER_AVATAR_URL=https://cdn.syncroom.ru/syncroom/bots/study-helper.png
APP_SEAT_BOT_SPORT_CHEERLEADER_AVATAR_URL=https://cdn.syncroom.ru/syncroom/bots/sport-cheerleader.png